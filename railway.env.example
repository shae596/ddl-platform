# =============================================================================
# Railway — configuration base de données (3 méthodes possibles)
# =============================================================================
#
# MÉTHODE A (la plus simple) — Connecter les services
#   1. Cliquez sur le service PostgreSQL
#   2. Onglet Connect (ou Settings → Connect)
#   3. Reliez-le au service ddl-platform
#   → Railway injecte automatiquement DATABASE_URL, PGHOST, PGPORT, etc.
#
# MÉTHODE B — Variable DB_URL manuelle
#   Service ddl-platform → Variables → Add Reference
#   DB_URL = ${{Postgres.DATABASE_URL}}
#
# MÉTHODE C — Variables PG* (injectées par Connect)
#   PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE
#
# ⚠️  SUPPRIMEZ sur ddl-platform si présentes :
#   DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD
#
# =============================================================================

APP_KEY=base64:...
APP_URL=https://ddl-platform-production.up.railway.app
APP_ENV=production
APP_DEBUG=false
DB_CONNECTION=pgsql

# Une de ces options suffit après Connect :
# DATABASE_URL  (auto)
# DB_URL        (référence manuelle)
# PGHOST + PGPORT + PGUSER + PGPASSWORD + PGDATABASE (auto)
