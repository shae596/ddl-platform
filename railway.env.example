# =============================================================================
# CHECKLIST Railway — erreur 500 = une de ces étapes manque
# =============================================================================
#
# ⚠️  Les variables saisies dans le DASHBOARD Railway écrasent railway.toml.
#     Supprimez les anciennes valeurs copiées depuis .env local !
#
# =============================================================================

# ÉTAPE 1 — Service PostgreSQL
#   Projet Railway doit avoir 2 services : ddl-platform + PostgreSQL
#
# ÉTAPE 2 — Variables OBLIGATOIRES (service Web → Variables)
#
#   APP_KEY     = base64:...  (php artisan key:generate --show)
#   APP_URL     = https://votre-domaine.up.railway.app  (PAS localhost!)
#   DB_URL      = Add Reference → PostgreSQL → DATABASE_URL
#
# ÉTAPE 3 — Supprimer / corriger ces valeurs SI présentes :
#
#   APP_ENV     ≠ local        → production
#   APP_DEBUG   ≠ true         → false
#   APP_URL     ≠ http://localhost:8001
#   DB_HOST     → supprimer si DB_URL est défini
#   DB_PASSWORD → supprimer si DB_URL est défini
#
# ÉTAPE 4 — Après déploiement réussi → Console Railway :
#
#   php artisan db:seed --force
#
# ÉTAPE 5 — Tester dans l'ordre :
#
#   https://votre-url.up.railway.app/up     → doit afficher {"status":"ok"}
#   https://votre-url.up.railway.app/login  → page de connexion
#
# ÉTAPE 6 — Si toujours erreur 500, mettre temporairement APP_DEBUG=true
#   pour voir le message exact dans le navigateur, puis remettre false.
#
# =============================================================================

APP_NAME=DDL
APP_ENV=production
APP_KEY=base64:COLLER_ICI
APP_DEBUG=false
APP_URL=https://VOTRE_URL.up.railway.app

DB_CONNECTION=pgsql
DB_URL=${{Postgres.DATABASE_URL}}
DB_SSLMODE=require

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
LOG_CHANNEL=stderr
